# Keyhole Developer Kit — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running 'make setup' or 'bootstrap.ps1'.
#
#   cp .env.example .env        (Linux / macOS / WSL2)
#   Copy-Item .env.example .env  (Windows PowerShell)
#
# .env is gitignored. Never commit credentials. .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────


# ── Local Test Runtime ────────────────────────────────────────────────────────
# URL that the SDK and CLI use to reach the local test runtime.
# Local development:  http://localhost:8080
# Dev Container:      http://test-runtime:8080  (set automatically by devcontainer)
KEYHOLE_RUNTIME_URL=http://localhost:8080


# ── MCP Governance Bridge (optional) ─────────────────────────────────────────
# Leave blank to run in local-only mode.
# Set these to connect to the live Keyhole governance controller.
#
# Operating mode:
#   local-only → KEYHOLE_MCP_URL is empty
#   governed   → KEYHOLE_MCP_URL points to https://mcp.keyholesolution.com
KEYHOLE_MCP_URL=
KEYHOLE_MCP_TOKEN=
KEYHOLE_MCP_RUN_TYPE=convergence.status.v0_1
KEYHOLE_MCP_TIMEOUT=10


# ── MCP Platform Endpoints (governed mode only) ───────────────────────────────
# Override only if you are using a non-standard deployment of the platform.
MCP_BASE_URL=https://mcp.keyholesolution.com
KEYHOLE_AUTH_SERVER=https://auth.keyholesolution.com/realms/keyhole-mcp


# ── CLI Configuration ─────────────────────────────────────────────────────────
# Directory where the CLI stores credentials and state.
# Defaults to $HOME/.keyhole if not set.
# KEYHOLE_HOME=


# ── Smoke Test Configuration ──────────────────────────────────────────────────
# Set MCP_AVAILABLE=true only when MCP credentials above are populated.
MCP_AVAILABLE=false
SMOKE_TEST_TIMEOUT=30
SKIP_EVENT_CHECK=false
EVENT_CHECK_REQUIRED=false
# PRE_SEED_TOKEN_FILE=   # Absolute path to pre-seeded token file (session reuse tests)


# ── Runtime Container Metadata ────────────────────────────────────────────────
RUNTIME_ENVIRONMENT=dev
