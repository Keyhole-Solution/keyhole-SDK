{
  "description": "Local-only smoke test for the Keyhole public runtime",
  "mode": "local-only",
  "prerequisites": [
    "Runtime running at http://localhost:8080",
    "No KEYHOLE_MCP_URL or KEYHOLE_MCP_TOKEN configured"
  ],
  "steps": [
    {
      "step": 1,
      "name": "health_check",
      "request": { "method": "GET", "path": "/healthz" },
      "expected": { "status_code": 200, "body": { "status": "ok" } }
    },
    {
      "step": 2,
      "name": "identity_check",
      "request": { "method": "GET", "path": "/identity" },
      "expected": {
        "status_code": 200,
        "body_contains": {
          "runtime_id": "keyhole-test-runtime",
          "governance_mode": "local-only"
        }
      }
    },
    {
      "step": 3,
      "name": "mode_check",
      "request": { "method": "GET", "path": "/mode" },
      "expected": {
        "status_code": 200,
        "body": {
          "mode": "local-only",
          "mcp_configured": false,
          "auditable_upstream": false
        }
      }
    },
    {
      "step": 4,
      "name": "state_check",
      "request": { "method": "GET", "path": "/state" },
      "expected": {
        "status_code": 200,
        "body_contains": { "realized_digests": [] }
      }
    },
    {
      "step": 5,
      "name": "realize_local",
      "request": {
        "method": "POST",
        "path": "/realize",
        "body": {
          "candidate_digest": "sha256:abc123localsmoke",
          "payload": { "test": true }
        }
      },
      "expected": {
        "status_code": 200,
        "body_contains": { "status": "ACCEPT", "digest": "sha256:abc123localsmoke" }
      }
    }
  ],
  "evidence_posture": "Local-only results are NOT auditable upstream. No Event Spine evidence is produced. Local success is valuable for development but is NOT constitutional proof.",
  "bridge_law_reference": "CE-V5-S40-07"
}
