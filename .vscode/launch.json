{
  "version": "0.2.0",
  "configurations": [
    {
      // Run the full test suite under the debugger.
      "name": "pytest: all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "justMyCode": true,
      "env": {
        "PYTHONDONTWRITEBYTECODE": "1"
      }
    },
    {
      // Run only unit tests.
      "name": "pytest: unit tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit/", "-v"],
      "justMyCode": true
    },
    {
      // Run only smoke tests (requires runtime + MCP_AVAILABLE=true).
      "name": "pytest: smoke tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/smoke/", "-v"],
      "justMyCode": true,
      "env": {
        "MCP_AVAILABLE": "true"
      }
    },
    {
      // Debug a specific keyhole CLI command interactively.
      "name": "keyhole: whoami",
      "type": "debugpy",
      "request": "launch",
      "module": "keyhole_cli.cli",
      "args": ["whoami"],
      "justMyCode": false
    },
    {
      // Verify local environment and compute repair plan.
      "name": "keyhole: doctor",
      "type": "debugpy",
      "request": "launch",
      "module": "keyhole_cli.cli",
      "args": ["doctor"],
      "justMyCode": false
    }
  ]
}
