{
  // ── Python ─────────────────────────────────────────────────────────────────
  // Interpreter: point at .venv relative to the workspace.
  // VS Code Python extension auto-detects .venv on Windows (Scripts/) and
  // Linux/macOS (bin/) — run 'make setup' or 'bootstrap.ps1' first.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // ── Testing ────────────────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests/"],
  "python.testing.unittestEnabled": false,

  // ── Editor ─────────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.rulers": [88],
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // ── File Exclusions ────────────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/*.egg-info": true
  },

  // ── Terminal ───────────────────────────────────────────────────────────────
  "terminal.integrated.env.linux": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "terminal.integrated.env.osx": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "terminal.integrated.env.windows": {
    "PYTHONDONTWRITEBYTECODE": "1"
  },

  // ── Docker ─────────────────────────────────────────────────────────────────
  "docker.defaultRegistryPath": "ghcr.io/keyhole-solution"
}
