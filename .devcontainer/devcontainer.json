{
  "name": "Keyhole Developer Kit",

  // Spin up the devcontainer alongside the test-runtime using the existing
  // docker-compose.yml plus the devcontainer-specific override.
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",

  // postCreateCommand runs once after the container is built.
  // It installs the SDK + CLI in editable mode and validates the environment.
  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Port 8080 is already mapped to the host by docker-compose.yml.
  // Declaring it here ensures VS Code forwards it into the devcontainer terminal
  // so 'curl http://localhost:8080/healthz' works inside the container too.
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Keyhole Test Runtime",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      // Extensions are installed automatically inside the devcontainer.
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      // Devcontainer-specific settings override .vscode/settings.json where needed.
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests/"],
        "python.testing.unittestEnabled": false,
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
